<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.1"
  xsi:type="MailApp">

  <Id>7d7b9d8e-1111-4444-9999-123456789abc</Id>

  <Version>1.0.0.0</Version>

  <ProviderName>Rojamo</ProviderName>

  <DefaultLocale>en-AU</DefaultLocale>

  <DisplayName DefaultValue="Corporate Disclaimer"/>

  <Description DefaultValue="Automatically inserts disclaimer."/>

  <IconUrl DefaultValue="https://rjmoule.github.io/icon-64.png"/>

  <HighResolutionIconUrl DefaultValue="https://rjmoule.github.io/icon-64.png"/>

  <SupportUrl DefaultValue="https://rjmoule.github.io"/>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets DefaultMinVersion="1.10">
      <Set Name="Mailbox"/>
    </Sets>
  </Requirements>

  <Permissions>ReadWriteItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit"/>
  </Rule>

  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <VersionOverrides
    xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1"
    xsi:type="VersionOverridesV1_1">

    <Requirements>
      <bt:Sets DefaultMinVersion="1.10">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">

        <DesktopFormFactor>

          <FunctionFile resid="Commands.Url"/>

          <ExtensionPoint xsi:type="LaunchEvent">

            <LaunchEvents>

              <LaunchEvent
                Type="OnNewMessageCompose"
                FunctionName="onComposeHandler"/>

              <LaunchEvent
                Type="OnMessageReplyCompose"
                FunctionName="onComposeHandler"/>

              <LaunchEvent
                Type="OnMessageForwardCompose"
                FunctionName="onComposeHandler"/>

            </LaunchEvents>

            <SourceLocation resid="Commands.Url"/>

          </ExtensionPoint>

        </DesktopFormFactor>

      </Host>
    </Hosts>

    <Resources>

      <bt:Urls>

        <bt:Url
          id="Commands.Url"
          DefaultValue="https://rjmoule.github.io/commands.html"/>

      </bt:Urls>

      <bt:Images>

        <bt:Image
          id="Icon.64"
          DefaultValue="https://rjmoule.github.io/icon-64.png"/>

      </bt:Images>

      <bt:ShortStrings>

        <bt:String
          id="GroupLabel"
          DefaultValue="Disclaimer"/>

      </bt:ShortStrings>

    </Resources>

  </VersionOverrides>

</OfficeApp>